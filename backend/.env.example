SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-from-project-settings-api
ANTHROPIC_API_KEY=sk-ant-...

# Optional / legacy. Modern Supabase signs JWTs with ES256 and auth.py verifies
# them via the project's public JWKS, so this is unused. Leave blank unless you
# are on an older HS256 project.
SUPABASE_JWT_SECRET=
