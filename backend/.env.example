SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-from-project-settings-api
ANTHROPIC_API_KEY=sk-ant-...

# Optional / legacy. Modern Supabase signs JWTs with ES256 and auth.py verifies
# them via the project's public JWKS, so this is unused. Leave blank unless you
# are on an older HS256 project.
SUPABASE_JWT_SECRET=

# CORS allowlist (comma-separated). Defaults cover local dev. In production,
# APPEND your deployed frontend origin, e.g.
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Rate limiting (in-memory, per-instance). Defaults are generous; lower for a
# stricter beta. RATE_LIMIT_ENABLED=false turns it off entirely.
# RATE_LIMIT_GENERAL=120
# RATE_LIMIT_AI=20
# RATE_LIMIT_WINDOW_SECONDS=60
